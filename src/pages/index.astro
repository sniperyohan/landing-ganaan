<script is:inline src="//t1.daumcdn.net/mapjsapi/bundle/postcode/prod/postcode.v2.js"></script>

<script>
  const INQUIRY_URL = "여기에_나중에_웹앱_URL_붙여넣기";

  // 햄버거 메뉴 열기/닫기
  window.toggleMenu = function () {
    document.getElementById("navMenu").classList.toggle("open");
  };
  window.closeMenu = function () {
    document.getElementById("navMenu").classList.remove("open");
  };

  window.openInquiryModal = function () {
    document.getElementById("inquiryModal").classList.add("active");
  };
  window.closeInquiryModal = function () {
    document.getElementById("inquiryModal").classList.remove("active");
  };

  // 카카오 주소 검색 (레이어 방식)
  window.searchAddr = function (targetId) {
    const layer = document.getElementById("addrLayer");
    const wrap = document.getElementById("addrWrap");
    wrap.innerHTML = "";
    new daum.Postcode({
      width: "100%",
      height: "100%",
      oncomplete: function (data) {
        document.getElementById(targetId).value = data.roadAddress;
        layer.classList.remove("active");
      },
    }).embed(wrap);
    layer.classList.add("active");
  };

  window.closeAddrLayer = function () {
    document.getElementById("addrLayer").classList.remove("active");
  };

  document.getElementById("addrLayer").addEventListener("click", function (e) {
    if (e.target === this) window.closeAddrLayer();
  });

  // 개인정보처리방침 / 이용약관 팝업
  window.openPolicy = function (type) {
    document.getElementById("policy-privacy").style.display =
      type === "privacy" ? "block" : "none";
    document.getElementById("policy-terms").style.display =
      type === "terms" ? "block" : "none";
    document.getElementById("policyLayer").classList.add("active");
  };
  window.closePolicy = function () {
    document.getElementById("policyLayer").classList.remove("active");
  };
  document.getElementById("policyLayer").addEventListener("click", function (e) {
    if (e.target === this) window.closePolicy();
  });

  document
    .getElementById("inquiryModal")
    .addEventListener("click", function (e) {
      if (e.target === this) window.closeInquiryModal();
    });

  document
    .getElementById("inquiryForm")
    .addEventListener("submit", function (e) {
      e.preventDefault();
      const form = e.target;
      const btn = form.querySelector(".inquiry-submit");
      const result = document.getElementById("inquiryResult");
      btn.disabled = true;
      btn.textContent = "보내는 중...";
      result.textContent = "";
      const formData = new FormData(form);
      fetch(INQUIRY_URL, { method: "POST", body: formData })
        .then(function () {
          result.style.color = "#2e7d32";
          result.textContent =
            "✅ 견적 문의가 접수되었습니다. 곧 연락드리겠습니다!";
          form.reset();
          btn.disabled = false;
          btn.textContent = "견적 문의 보내기";
          setTimeout(window.closeInquiryModal, 2500);
        })
        .catch(function () {
          result.style.color = "#c62828";
          result.textContent =
            "❌ 전송에 실패했어요. 잠시 후 다시 시도해주세요.";
          btn.disabled = false;
          btn.textContent = "견적 문의 보내기";
        });
    });
</script>
