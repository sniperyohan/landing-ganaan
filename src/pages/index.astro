  .process-steps {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: flex-start;
    gap: 0;
  }
  .step {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 180px;
  }
  .step-num {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: #f5c518;
    color: #2d3748;
    font-weight: 800;
    font-size: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
    box-shadow: 0 6px 14px rgba(245, 197, 24, 0.45);
    border: 3px solid #fff;
    outline: 2px solid #f5c518;
    outline-offset: 2px;
    z-index: 2;
    position: relative;
    transform: scale(0);
    transition: transform 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .step-txt {
    font-size: 14px;
    font-weight: 700;
    color: #fff !important;
    line-height: 1.4;
    background: #2d3748 !important;
    padding: 8px 14px !important;
    border-radius: 20px !important;
    margin-top: 16px;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.8s ease,
      transform 0.8s ease;
  }
  .step:not(:last-child)::before {
    content: "";
    position: absolute;
    top: 32px;
    left: 50%;
    width: 0;
    height: 3px;
    background: #f0e2a8;
    z-index: 1;
    transition: width 0.8s ease;
  }

  .moving-process.show .step:nth-child(1) .step-num {
    transition-delay: 0.2s;
  }
  .moving-process.show .step:nth-child(2) .step-num {
    transition-delay: 0.9s;
  }
  .moving-process.show .step:nth-child(3) .step-num {
    transition-delay: 1.6s;
  }
  .moving-process.show .step:nth-child(4) .step-num {
    transition-delay: 2.3s;
  }
  .moving-process.show .step:nth-child(5) .step-num {
    transition-delay: 3s;
  }

  .moving-process.show .step:nth-child(1) .step-txt {
    transition-delay: 0.4s;
  }
  .moving-process.show .step:nth-child(2) .step-txt {
    transition-delay: 1.1s;
  }
  .moving-process.show .step:nth-child(3) .step-txt {
    transition-delay: 1.8s;
  }
  .moving-process.show .step:nth-child(4) .step-txt {
    transition-delay: 2.5s;
  }
  .moving-process.show .step:nth-child(5) .step-txt {
    transition-delay: 3.2s;
  }

  .moving-process.show .step:nth-child(1)::before {
    transition-delay: 0.6s;
  }
  .moving-process.show .step:nth-child(2)::before {
    transition-delay: 1.3s;
  }
  .moving-process.show .step:nth-child(3)::before {
    transition-delay: 2s;
  }
  .moving-process.show .step:nth-child(4)::before {
    transition-delay: 2.7s;
  }

  .moving-process.show .step:not(:last-child)::before {
    width: 100%;
  }
  .moving-process.show .step-num {
    transform: scale(1);
  }
  .moving-process.show .step-txt {
    opacity: 1;
    transform: translateY(0);
  }

