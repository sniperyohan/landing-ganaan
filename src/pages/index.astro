    <script>
      document.addEventListener("DOMContentLoaded", function () {
        var process = document.querySelector(".moving-process");
        if (process) {
          var observer = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                  process.classList.add("show");
                  observer.unobserve(process);
                }
              });
            },
            { threshold: 0.4 },
          );
          observer.observe(process);
        }

        // 인사말 섹션 등장 애니메이션
        var aboutObserver = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("show");
              }
            });
          },
          { threshold: 0.8 },
        );
        document.querySelectorAll(".about-section .reveal").forEach(function (el) {
          aboutObserver.observe(el);
        });

        // 전체 섹션 스크롤 등장 효과
        var fadeObserver = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("show");
                fadeObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.33 }
        );
        var fadeEls = document.querySelectorAll(".section, .cta-banner");
        fadeEls.forEach(function (el) {
          el.classList.add("fade-up");
          fadeObserver.observe(el);
        });
        // 안전장치: 화면에 이미 보이는 섹션은 즉시 표시 + 3초 후 전부 강제 표시
        setTimeout(function () {
          fadeEls.forEach(function (el) {
            el.classList.add("show");
          });
        }, 3000);
      });
    </script>
